# === Zauberer LIAR – Apache-Konfiguration (IONOS) ===

# MultiViews/Verzeichnis-Auflösung abschalten, damit alte /pfad/-URLs
# nicht VOR den Rewrite-Regeln als 404/Directory abgefangen werden.
Options -MultiViews

RewriteEngine On

# === HTTPS + www → non-www erzwingen ===
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# === 301-Weiterleitungen: alte WordPress-URLs → neue statische Struktur ===
# Konsequent mod_rewrite (NICHT Redirect/RedirectMatch aus mod_alias),
# da mod_rewrite früh greift und Trailing-Slash-Verzeichnisse sauber fängt.
# Reihenfolge: spezifischere (längere/tiefere) Pfade ZUERST.

# --- Close-up / Tischzauberei / Walk-Act ---
RewriteRule ^close-up-aus-frankreich/tisch-zauberer/?$    /tisch-zauberer.html    [L,R=301]
RewriteRule ^close-up-aus-frankreich/walk-act-zauberer/?$ /walk-act-zauberer.html [L,R=301]
RewriteRule ^close-up-aus-frankreich/slider-zauberer/?$   /close-up-zauberer.html [L,R=301]
RewriteRule ^close-up-aus-frankreich(/.*)?$               /close-up-zauberer.html [L,R=301]

# --- Stand-up / Kinderzauberer / Zaubershow (tiefste Pfade zuerst) ---
RewriteRule ^stand-up-aus-frankreich/kinderzauberer(/.*)?$ /kinderzauberer.html       [L,R=301]
RewriteRule ^stand-up-aus-frankreich/zaubershow-nrw/?$     /zaubershow-erwachsene.html [L,R=301]
RewriteRule ^stand-up-aus-frankreich(/.*)?$                /buehnenshow.html           [L,R=301]

# --- Referenzen ---
RewriteRule ^referenzen-zauberer-zauberkunstler-nrw(/.*)?$ /referenzen.html [L,R=301]

# --- Foto-Galerie (alte /galerie/*) ---
RewriteRule ^galerie(/.*)?$       /fotogalerie.html  [L,R=301]

# --- Video-Galerie (alle Unterseiten) ---
RewriteRule ^videogalerie(/.*)?$  /videogalerie.html [L,R=301]

# --- Stadt-/Regions-Seiten (vorerst Startseite; später eigene Stadt-Seiten) ---
RewriteRule ^zauberer-gladbeck/?$ /index.html [L,R=301]
RewriteRule ^zauberer-nrw-2(/.*)?$ /index.html [L,R=301]

# --- Rechtliches (spezifische Unterpfade zuerst) ---
RewriteRule ^datenschutzerklaerung/?$  /datenschutz.html [L,R=301]
RewriteRule ^kontakt/impressum/?$      /impressum.html   [L,R=301]
RewriteRule ^kontakt/agbs/?$           /agb.html         [L,R=301]
RewriteRule ^kontakt/?$                /kontakt.html     [L,R=301]

# --- Alte WordPress-Query-IDs (?p=NNNN) auf Startseite ---
RewriteCond %{QUERY_STRING} (^|&)p=[0-9]+
RewriteRule ^$ /index.html? [L,R=301]

# === Performance: Caching ===
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# HTML immer frisch laden (Relaunch-Änderungen sofort sichtbar; CSS/JS via ?v= gebustet)
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
</IfModule>

# === Performance: GZIP-Komprimierung ===
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml text/xml
</IfModule>

# === Sicherheit ===
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# 404-Seite (optional, sobald 404.html existiert)
# ErrorDocument 404 /404.html
